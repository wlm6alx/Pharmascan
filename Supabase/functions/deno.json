{ 
    "name": "pharmascan-api",
    "version": "1.0.0",

    "compilerOptions": {
        "lib": ["deno.ns", "dom", "esnext"],
        "strict": true
    },

    "tasks": {
        "dev": "deno run --watch --allow-env --allow-net --allow-read functions/server.ts",
        "start": "deno run --allow-env --allow-net --allow-read functions/server.ts",
        "check": "deno check functions/server.ts",
        "fmt": "deno fmt",
        "lint": "deno lint",
        "test": "deno test --allow-env --allow-net --allow-read functions/**/*/test.ts"
    },

    "fmt": {
        "lineWidth": 100,
        "indentWidth": 2,
        "singleQuote": false,
        "semiColons": true,
        "include": ["functions/**/*.ts"],
        "exclude": [".supabase/", "deno.lock"]
    },

    "lint": {
        "rules": {
            "tags": ["recommended"]
        },
        "include": ["functions/**/*.ts"],
        "exclude": [".supabase/"]
    },

    "exclude": [
        ".supabase/",
        "deno.lock",
        "node_modules"
    ],

    "imports": {
        "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.93.3",
        "@std/assert": "jsr:@std/assert@1.0.9",
        "@/": "./"
    }
}